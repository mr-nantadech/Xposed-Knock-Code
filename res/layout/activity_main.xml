<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- ── Warning banner (visible only when no passcode is set) ── -->
        <LinearLayout
            android:id="@+id/warning_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/warning_bg"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/warning_no_passcode"
                android:textColor="@color/warning_text"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <!-- ── Section: Security ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:text="@string/section_security"
            android:textColor="@color/section_header"
            android:textSize="12sp"
            android:textAllCaps="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            android:background="@color/card_bg"
            android:elevation="2dp">

            <!-- Change knock code -->
            <LinearLayout
                android:id="@+id/row_change_code"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_title_change_code"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_description_change_code"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:paddingTop="3dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:background="@color/divider"/>

            <!-- Locked apps -->
            <LinearLayout
                android:id="@+id/row_locked_apps"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_title_locked_apps"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pref_description_locked_apps"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:paddingTop="3dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ── Section: Appearance ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:text="@string/section_appearance"
            android:textColor="@color/section_header"
            android:textSize="12sp"
            android:textAllCaps="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            android:background="@color/card_bg"
            android:elevation="2dp">

            <!-- Draw fill row -->
            <LinearLayout
                android:id="@+id/row_draw_fill"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_title_draw_fill"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_description_draw_fill"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:paddingTop="3dp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_draw_fill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:background="@color/divider"/>

            <!-- Draw lines row -->
            <LinearLayout
                android:id="@+id/row_draw_lines"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_title_draw_lines"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_description_draw_lines"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:paddingTop="3dp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_draw_lines"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
